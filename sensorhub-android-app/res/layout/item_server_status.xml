<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/info_card_margin"
    android:layout_marginEnd="@dimen/info_card_margin"
    android:layout_marginTop="6dp"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@color/md_theme_background"
    app:strokeColor="@color/md_theme_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/server_status_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/info_card_padding"
            android:paddingEnd="4dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="?attr/selectableItemBackground">

            <View
                android:id="@+id/server_status_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/status_dot_background" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/server_status_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/server_status_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_toggle_server_details"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_expand_more"
                android:scaleType="centerInside"
                android:contentDescription="Toggle details" />

        </LinearLayout>

        <TextView
            android:id="@+id/server_status_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/info_card_padding"
            android:paddingEnd="@dimen/info_card_padding"
            android:paddingBottom="@dimen/info_card_padding"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="13sp"
            android:fontFamily="sans-serif"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
